#!/bin/sh
# rustup shell setup
# affix colons on either side of $PATH to simplify matching
case ":${PATH}:" in
    *:"/home/rkrsn/workspace/scarfbench-org/scarf/.cargo/bin":*)
        ;;
    *)
        # Prepending path in case a system-installed rustc needs to be overridden
        export PATH="/home/rkrsn/workspace/scarfbench-org/scarf/.cargo/bin:$PATH"
        ;;
esac
